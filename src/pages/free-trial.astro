---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="3-Day Premium Free Trial | Elite Host"
  description="Start your 3-day premium web hosting free trial with Elite Host. Enjoy lightning-fast SSD storage, free SSL, cPanel management, and expert support. No credit card required!"
  keywords="free trial hosting, web hosting free trial, 3 days free trial, elite host trial, free cpanel hosting, no credit card hosting"
>
  <!-- Hero Page Banner -->
  <div class="main-banner page-banner">
    <div class="img-up">
      <div class="container">
        <div class="row g-4 align-items-center">
          <div class="col-lg-6">
            <div class="inner-content">
              <span class="top-heading">3-DAYS RISK FREE</span>
              <h1>Experience Premium Hosting with Our Free Trial</h1>
              <h3>No credit card required, instant setup!</h3>
              <ul class="banner-list icon">
                <li><i class="bi bi-person-check me-2"></i>Full cPanel Access</li>
                <li><i class="bi bi-speedometer2 me-2"></i>LiteSpeed Web Servers</li>
                <li><i class="bi bi-clock me-2"></i>Instant Setup in 30s</li>
                <li><i class="bi bi-headset me-2"></i>24/7 Expert Support</li>
              </ul>
              <h4 class="mt-3"> <span>Starts at just</span> <sup>৳</sup> <strong>0</strong> <small>/3 days</small> </h4>
              <div class="inline-btns mt-3">
                <a class="btns one" href="#trial-plans">Choose Your Plan<i class="far fa-arrow-right"></i></a>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="text-center text-lg-end">
              <img src="/images/domain-img1.png" alt="Free Trial Web Hosting" class="img-fluid" width="450">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reused Plan Cards Section -->
  <section id="trial-plans" class="section-gap">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <div class="section-header center gap-bottom">
            <h2>Choose Your Trial Plan</h2>
            <p>See at a glance what each plan offers during your 3-day free trial.</p>
          </div>
        </div>
      </div>
      <div class="row g-4 justify-content-center">
        <!-- Package 1: Shared Hosting Trial -->
        <div class="col-lg-4 col-md-6 col-12">
          <div class="plans-design-one">
            <img src="/images/database.png" alt="icon" class="icon">
            <h3>Web Hosting Trial</h3>
            <p>Ideal for beginners and small businesses.</p>
            <h6>Free Trial</h6>
            <h4><sup>৳</sup> 0.00 <small>/3 days</small></h4>
            <a class="btns three" href="contact-us.html">Start Trial</a>
            <ul>
              <li><i class="ri-hard-drive-2-line"></i> 5 GB NVMe SSD Storage</li>
              <li><i class="fal fa-browser"></i> cPanel Control Panel</li>
              <li><i class="fal fa-globe"></i> Create up to 3 Websites</li>
              <li><i class="fal fa-lock"></i> Free SSL Certificate</li>
            </ul>
          </div>
        </div>

        <!-- Package 2: WordPress Hosting Trial -->
        <div class="col-lg-4 col-md-6 col-12">
          <div class="plans-design-one">
            <img src="/images/server.png" alt="icon" class="icon">
            <h3>WordPress Hosting Trial</h3>
            <p>Optimized for WordPress speed and security.</p>
            <h6>Free Trial</h6>
            <h4><sup>৳</sup> 0.00 <small>/3 days</small></h4>
            <a class="btns three" href="contact-us.html">Start Trial</a>
            <ul>
              <li><i class="ri-hard-drive-2-line"></i> 2 GB Disk Space</li>
              <li><i class="fal fa-browser"></i> cPanel Control Panel</li>
              <li><i class="fal fa-server"></i> 6GB Memory</li>
              <li><i class="fal fa-lock"></i> Free SSL Certificate</li>
            </ul>
          </div>
        </div>

        <!-- Package 3: Business Cloud Hosting Trial -->
        <div class="col-lg-4 col-md-6 col-12">
          <div class="plans-design-one">
            <img src="/images/servers.png" alt="icon" class="icon">
            <h3>Cloud Hosting Trial</h3>
            <p>Reliable, Scalable, Affordable, Secure, Profitable.</p>
            <h6>Free Trial</h6>
            <h4><sup>৳</sup> 0.00 <small>/3 days</small></h4>
            <a class="btns three" href="contact-us.html">Start Trial</a>
            <ul>
              <li><i class="ri-hard-drive-2-line"></i> 20 GB SSD Storage</li>
              <li><i class="fal fa-browser"></i> cPanel Control Panel</li>
              <li><i class="fal fa-server"></i> 6GB Memory</li>
              <li><i class="fal fa-lock"></i> Free SSL Certificate</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reused Solution Support Center Section -->
  <section class="section-gap">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-10 bg1 support">
          <div class="row g-4 align-items-center justify-content-between">
            <div class="col-lg-7">
              <div class="section-header">
                <h2>Our Solution Support Center</h2>
                <p>Our Solution Support Center provides expert assistance, troubleshooting, and guidance for seamless technical support.</p>
                <div class="mt-3">
                  <ul>
                    <li class="text-center"> <span class="icon"><img src="/images/talk.webp" alt=""></span>
                      <label class="content">0212 909 9656</label>
                    </li>
                    <li class="text-center"> <span class="icon"><img src="/images/support2.webp" alt=""></span>
                      <label class="content">24*7 Support</label>
                    </li>
                    <li class="text-center"> <span class="icon"><img src="/images/customer.webp" alt=""></span>
                      <label class="content">Talk to customer</label>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="col-lg-4">
              <div class="text-center text-lg-end"> <img src="/images/support-center.png" alt="Reseller Hosting"> </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reused Trial FAQs Section -->
  <section class="section-gap">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="section-header gap-bottom center">
            <h2>Free Trial Frequently Asked Questions</h2>
            <p>Got questions about our 3-day free trial? We've got answers.</p>
          </div>
        </div>
      </div>
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
          <ul class="accordion">
            <li>
              <h5>Is a credit card required to start the trial?</h5>
              <p>Absolutely not! We believe in a frictionless experience. You can sign up with just your name and email address, and your cPanel hosting account will be set up instantly.</p>
            </li>
            <li>
              <h5>What happens after the 3 days expire?</h5>
              <p>After 3 days, your trial account will be temporarily suspended. None of your data is deleted immediately. You can upgrade to a premium paid subscription to keep your website live.</p>
            </li>
            <li>
              <h5>Can I keep my data if I upgrade to a paid plan?</h5>
              <p>Yes, 100%! When you upgrade to any of our paid subscription plans, all of your files, databases, configurations, and email accounts are preserved exactly as they are.</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
